# Azure Deploy Environment Variables

# Anthropic API Key za AI integraciju
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Google OAuth (ako koristiš Google login)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Database Connection (ako koristiš Cloud SQL umjesto SQLite)
DATABASE_URL=Server=xxx.database.windows.net;Database=BookReview;User Id=admin@xxx;Password=xxxxx;

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# Azure Storage (za backup logs/database)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxxxx;EndpointSuffix=core.windows.net

# Logging
LOG_LEVEL=Information

# Docker Registry (za Azure Container Registry)
DOCKER_REGISTRY=myregistry.azurecr.io
DOCKER_USERNAME=<username>
DOCKER_PASSWORD=<password>

# Azure Web App
AZURE_APP_NAME=book-review-app-<unique-suffix>
AZURE_RESOURCE_GROUP=BookReviewRG
