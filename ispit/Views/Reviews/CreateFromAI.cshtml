@{
    ViewData["Title"] = "Kreiraj Recenziju - AI";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active" aria-current="page">AI Recenzija</li>
    </ol>
</nav>

<section class="panel-card mb-4">
    <div class="panel-header">
        <div>
            <p class="section-label">AI Asistent</p>
            <h2>🤖 Kreiraj Recenziju putem AI-a</h2>
            <p class="panel-note mb-0">Napiši što misliš o knjizi, AI će automatski parsirati ocjenu i sentimen.</p>
        </div>
    </div>
</section>

<section class="panel-card ai-examples-section mb-4">
    <h3>📝 Primjeri kako napisati:</h3>
    <div class="examples-list">
        <div class="example-item">
            <code>"Harry Potter je fantastičan! Ocjena 5, preporuka da"</code>
        </div>
        <div class="example-item">
            <code>"A Game of Thrones je dobar ali malo dugačak, ocjena 4"</code>
        </div>
        <div class="example-item">
            <code>"The Fellowship of the Ring - ne sviđa mi se, ocjena 2"</code>
        </div>
        <div class="example-item">
            <code>"Hobbit - super knjiga, odličan fantasy, 5 zvjezdica!"</code>
        </div>
    </div>
</section>

<section class="panel-card ai-input-section mb-4">
    <form id="aiForm">
        <div class="form-group">
            <label for="prompt" class="form-label"><strong>Što misliš o knjizi?</strong></label>
            <textarea
                class="form-control"
                id="prompt"
                rows="6"
                placeholder="Primjer: Harry Potter je odličan! Preporuka da, ocjena 5, fantasy je super!"
                required></textarea>
            <small class="form-text d-block mt-2">
                <strong>Dostupne knjige u katalogu:</strong>
                @{
                    var bookTitles = (List<string>)ViewBag.BookTitles;
                }
                @if (bookTitles.Any())
                {
                    @string.Join(", ", bookTitles)
                }
                else
                {
                    <span>Trenutno nema knjiga u katalogu.</span>
                }
            </small>
        </div>

        <button type="submit" class="btn btn-primary btn-lg">🚀 Kreiraj putem AI-a</button>
    </form>

    <div id="result" class="mt-4"></div>
</section>

<section class="panel-card ai-features-section">
    <h3>🔧 Što radi AI parser:</h3>
    <ul class="features-list">
        <li>✅ Ekstrahira naziv knjige iz teksta</li>
        <li>✅ Ekstrahira ocjenu (1-5 ili ključne riječi kao "odličan" → 5)</li>
        <li>✅ Ekstrahira sentiment (Positive, Negative, Neutral, Enthusiastic)</li>
        <li>✅ Pravi preporuku (ako je ocjena viša ili kaže "preporuka")</li>
    </ul>
</section>

<script>
document.getElementById('aiForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const prompt = document.getElementById('prompt').value;
    const resultDiv = document.getElementById('result');

    resultDiv.innerHTML = '⏳ Čekam AI odgovor...';

    try {
        const response = await fetch('/reviews/create-from-ai', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: prompt })
        });

        const data = await response.json();

        if (response.ok) {
            resultDiv.innerHTML = `
                <div class="alert alert-success">
                    <h5>✅ ${data.message}</h5>
                    <hr />
                    <p><strong>Knjiga:</strong> ${data.review.bookTitle}</p>
                    <p><strong>Ocjena:</strong> ${data.review.score}/5 ${'⭐'.repeat(data.review.score)}</p>
                    <p><strong>Sentiment:</strong> ${data.review.sentiment}</p>
                    <p><strong>Komentar:</strong> ${data.review.comment}</p>
                    <hr />
                    <small class="text-success">✅ Recenzija ID: ${data.reviewId}</small>
                </div>
            `;
        } else {
            resultDiv.innerHTML = `
                <div class="alert alert-danger">
                    <h5>❌ Greška</h5>
                    <p><strong>Greška:</strong> ${data.error}</p>
                    ${data.suggestion ? `<p><strong>Prijedlog:</strong> ${data.suggestion}</p>` : ''}
                </div>
            `;
        }
    } catch (error) {
        resultDiv.innerHTML = `<div class="alert alert-danger">❌ Greška: ${error.message}</div>`;
    }
});
</script>

<style>
    .ai-examples-section,
    .ai-input-section,
    .ai-features-section {
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .ai-examples-section h3,
    .ai-features-section h3 {
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .examples-list {
        display: grid;
        gap: 1rem;
    }

    .example-item {
        padding: 1rem;
        background-color: rgba(13, 110, 253, 0.05);
        border-radius: 0.375rem;
        border-left: 3px solid #0d6efd;
    }

    .example-item code {
        background-color: transparent;
        color: #0d6efd;
        padding: 0;
        border: none;
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
        word-break: break-word;
    }

    .features-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .features-list li {
        margin-bottom: 0.75rem;
        padding-left: 0.5rem;
    }

    textarea#prompt {
        font-size: 1rem;
        line-height: 1.6;
        width: 100%;
        box-sizing: border-box;
        resize: vertical;
    }

    .ai-input-section .btn-primary {
        width: 100%;
        margin-top: 1rem;
    }
</style>
