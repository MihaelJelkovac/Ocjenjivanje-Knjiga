@model Review
@{
    ViewData["Title"] = "Detalji recenzije";
    bool canDelete = ViewBag.CanDelete == true;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item"><a asp-controller="Reviews" asp-action="Index">Recenzije</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <p class="section-label">Details</p>
            <h2>@Model.Title</h2>
        </div>
        <span class="rating-pill">@Model.Score / 5</span>
    </div>

    <p><strong>Knjiga:</strong> <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.BookId">@Model.Book.Title</a></p>
    <p><strong>Korisnik:</strong> <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.UserId">@Model.User.FullName</a></p>
    <p><strong>Sentiment:</strong> @Model.Sentiment</p>
    <p><strong>Preporuka:</strong> @(Model.IsRecommended ? "Da" : "Ne")</p>
    <p><strong>Datum:</strong> @Model.ReviewedAt.ToString("dd.MM.yyyy. HH:mm")</p>
    <p>@Model.Comment</p>

    @if (canDelete)
    {
        <div class="d-flex gap-2 mt-3">
            <a class="btn btn-secondary" asp-action="Index">Natrag na recenzije</a>
            <button type="button" class="btn btn-danger" id="btn-delete-review" data-id="@Model.Id">Obriši recenziju</button>
        </div>
    }
</section>

@if (canDelete)
{
    <script>
        document.getElementById('btn-delete-review')?.addEventListener('click', async function () {
            if (!confirm('Jeste li sigurni da želite obrisati ovu recenziju?')) {
                return;
            }
            const id = this.dataset.id;
            try {
                const response = await fetch(`/recenzije/delete/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
                });
                const data = await response.json();
                if (data.success) {
                    window.location.href = '/recenzije';
                } else {
                    alert('Greška: ' + data.message);
                }
            } catch {
                alert('Greška pri brisanju recenzije');
            }
        });
    </script>
}
