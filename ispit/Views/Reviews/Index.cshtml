@model IReadOnlyList<Review>
@{
    ViewData["Title"] = "Recenzije";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active" aria-current="page">Recenzije</li>
    </ol>
</nav>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <div>
                <a class="btn btn-primary" asp-action="Create">Dodaj recenziju</a>
            </div>
            <h2>Recenzije knjiga</h2>
        </div>
        <span class="panel-note">@Model.Count zapisa</span>
    </div>

    <!-- Search Form -->
    <form class="search-form mb-3" data-search-url="/Reviews/Search">
        <div class="form-group">
            <label for="search-input" class="form-label">Pretraži recenzije</label>
            <div class="input-group">
                <input type="text" id="search-input" class="form-control" placeholder="Unesite naziv...">
                <button type="reset" class="btn btn-outline-secondary">Očisti</button>
            </div>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>Naslov</th>
                    <th>Ocjena</th>
                    <th>Knjiga</th>
                    <th>Korisnik</th>
                    <th>Datum</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model)
                {
                    <tr class="review-row" data-id="@review.Id">
                        <td><a asp-action="Details" asp-route-id="@review.Id">@review.Title</a></td>
                        <td>@review.Score/5</td>
                        <td><a asp-controller="Books" asp-action="Details"
                                   asp-route-id="@review.BookId">@review.Book.Title</a></td>
                            <td>@review.User.FullName</td>
                            <td>@review.ReviewedAt.ToString("dd.MM.yyyy.")</td>
                        </tr>
                        <tr class="review-actions-row" data-review-id="@review.Id">
                            <td colspan="5">
                                <div class="review-actions">
                                    <a href="/reviews/create-from-ai" class="btn btn-sm btn-outline-primary">
                                        🤖 Kreiraj AI recenziju
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

<style>
    .review-row {
        position: relative;
    }

    .review-actions-row {
        display: none;
        background-color: #f8f9fa;
        overflow: hidden;
    }

    .review-actions-row.show {
        display: table-row;
    }

    .review-actions {
        padding: 0.75rem 0;
        animation: slideDown 0.3s ease-out;
        display: flex;
        gap: 0.5rem;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-100%);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .review-row:hover + .review-actions-row {
        display: table-row;
    }

    .review-actions-row:hover {
        display: table-row;
    }

    .btn-outline-primary:hover {
        background-color: #0d6efd;
        color: white;
        transform: translateY(-2px);
        transition: all 0.2s ease;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const reviewRows = document.querySelectorAll('.review-row');

    reviewRows.forEach(row => {
        const reviewId = row.getAttribute('data-id');
        const actionsRow = document.querySelector(`.review-actions-row[data-review-id="${reviewId}"]`);

        if (actionsRow) {
            row.addEventListener('mouseenter', function() {
                actionsRow.classList.add('show');
            });

            row.addEventListener('mouseleave', function() {
                actionsRow.classList.remove('show');
            });

            actionsRow.addEventListener('mouseenter', function() {
                actionsRow.classList.add('show');
            });

            actionsRow.addEventListener('mouseleave', function() {
                actionsRow.classList.remove('show');
            });
        }
    });
});
</script>
