<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ocijenjivanje Knjiga</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Lab2.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="app-nav mb-4">
            <div class="container-fluid app-nav-inner">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Ocijenjivanje
                    Knjiga</a>
                <ul class="app-nav-list">
                    <li>
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Početna</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Home" asp-action="RatingArena">Rating Arena</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Books" asp-action="Index">Knjige</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Authors" asp-action="Index">Autori</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Genres" asp-action="Index">Žanrovi</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Publishers" asp-action="Index">Izdavači</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Reviews" asp-action="Index">Recenzije</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-controller="Users" asp-action="Index">Korisnici</a>
                    </li>
                    <li>
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer app-footer text-muted">
        <div class="container">
            &copy; 2026 - Ocijenjivanje Knjiga
        </div>
    </footer>
        @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
