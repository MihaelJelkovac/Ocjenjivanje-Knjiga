@model IReadOnlyList<Publisher>
@{
    ViewData["Title"] = "Izdavači";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active" aria-current="page">Izdavači</li>
    </ol>
</nav>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <p class="section-label">Index</p>
            <h2>Izdavači</h2>
        </div>
        <span class="panel-note">@Model.Count zapisa</span>
    </div>

    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Lokacija</th>
                    <th>Osnovan</th>
                    <th>Knjige</th>`n                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var publisher in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@publisher.Id">@publisher.Name</a></td>
                        <td>@publisher.City, @publisher.Country</td>
                        <td>@publisher.FoundedOn.ToString("yyyy")</td>
                        <td>@publisher.Books.Count</td>
                        <td>
                            <a class="app-cta-link" asp-action="Details" asp-route-id="@publisher.Id">Profil</a>
                            <a class="app-cta-link" asp-action="Edit" asp-route-id="@publisher.Id">Ažuriranje</a>
                            <button type="button" class="app-cta-link btn-delete text-danger" data-id="@publisher.Id">Briši</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
<script>
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('btn-delete')) {
        e.preventDefault();
        const id = e.target.dataset.id;
        
        if (confirm('Jeste li sigurni da želite obrisati ovaj zapis?')) {
            fetch('/Publishers/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: new URLSearchParams({ id: id })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const row = e.target.closest('tr');
                    row.style.transition = 'opacity 0.3s ease-out';
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                } else {
                    alert('Greška: ' + data.message);
                }
            })
            .catch(() => alert('Greška pri brisanju'));
        }
    }
});
</script>
}
